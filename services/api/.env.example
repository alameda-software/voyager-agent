# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/voyager

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=your-secret-key
JWT_ALGORITHM=HS256

# LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Note: LetsFG and swoop don't need API keys
# Just install them: pip install letsfg swoop
# Star LetsFG's GitHub repo for free access: https://github.com/LetsFG/LetsFG
